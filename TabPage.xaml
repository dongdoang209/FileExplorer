<UserControl x:Class="FileExplorer.TabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.ContextMenu>
        <ContextMenu x:Name="RootContextMenu">
            <MenuItem Header="📁 打开" Click="OpenItem_Click"/>
            <MenuItem Header="📂 在新标签页中打开" Click="OpenInNewTab_Click"/>
            <Separator/>
            <MenuItem Header="📄 新建文件夹" Click="NewFolder_Click"/>
            <Separator/>
            <MenuItem Header="✂️ 剪切" Click="Cut_Click"/>
            <MenuItem Header="📋 复制" Click="Copy_Click"/>
            <MenuItem Header="📝 粘贴" Click="Paste_Click"/>
            <MenuItem Header="📋 重命名" Click="Rename_Click"/>
            <Separator/>
            <MenuItem Header="ℹ️ 属性" Click="Properties_Click"/>
            <MenuItem Header="🗑️ 删除" Click="Delete_Click"/>
            <Separator/>
            <MenuItem Header="🔄 刷新" Click="Refresh_Click"/>
        </ContextMenu>
    </UserControl.ContextMenu>
    
    <Grid Background="{DynamicResource BgPrimary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 主内容区 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧导航面板 -->
            <Border Grid.Column="0" Background="{DynamicResource BgSecondary}" Margin="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 快速访问 -->
                    <TextBlock Grid.Row="0" Text="快速访问" FontWeight="SemiBold" 
                              Foreground="{DynamicResource FgAccent}" Margin="12,12,12,8"/>
                    
                    <ListBox x:Name="QuickAccessList" Grid.Row="1" Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="QuickAccessList_SelectionChanged">
                        <ListBoxItem Content="🖥️ 此电脑" Tag="thispc"/>
                        <ListBoxItem Content="🏠 桌面" Tag="%USERPROFILE%\Desktop"/>
                        <ListBoxItem Content="📥 下载" Tag="%USERPROFILE%\Downloads"/>
                        <ListBoxItem Content="📄 文档" Tag="%USERPROFILE%\Documents"/>
                        <ListBoxItem Content="🖼️ 图片" Tag="%USERPROFILE%\Pictures"/>
                        <ListBoxItem Content="🎵 音乐" Tag="%USERPROFILE%\Music"/>
                        <ListBoxItem Content="🎬 视频" Tag="%USERPROFILE%\Videos"/>
                    </ListBox>
                    
                    <!-- 驱动器 -->
                    <TextBlock Grid.Row="2" Text="驱动器" FontWeight="SemiBold" 
                              Foreground="{DynamicResource FgAccent}" Margin="12,12,12,8"/>
                    
                    <ListBox x:Name="DriveList" Grid.Row="3" Background="Transparent"
                             BorderThickness="0"
                             SelectionChanged="DriveList_SelectionChanged"/>
                </Grid>
            </Border>
            
            <!-- 文件列表 / 此电脑视图 -->
            <Grid Grid.Column="1" Background="{DynamicResource BgPrimary}">
                <!-- 此电脑标题 -->
                <Grid Visibility="Visible" x:Name="ThisPCPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 标题 -->
                    <StackPanel Grid.Row="0" Margin="20">
                        <TextBlock Text="🖥️ 此电脑" FontSize="28" FontWeight="Bold" 
                                  Foreground="{DynamicResource FgPrimary}"/>
                        <TextBlock Text="快速访问磁盘和文件夹" FontSize="14" 
                                  Foreground="{DynamicResource FgSecondary}" Margin="0,8,0,20"/>
                    </StackPanel>
                    
                    <!-- 驱动器列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,0">
                        <ItemsControl x:Name="DriveGrid">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                
                <!-- 文件列表 -->
                <ListBox x:Name="FileList" Background="Transparent" BorderThickness="0"
                         MouseDoubleClick="FileList_MouseDoubleClick"
                         SelectionMode="Extended"
                         Visibility="Collapsed">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="📁 打开" Click="OpenItem_Click"/>
                            <MenuItem Header="📂 在新标签页中打开" Click="OpenInNewTab_Click"/>
                            <Separator/>
                            <MenuItem Header="✂️ 剪切" Click="Cut_Click"/>
                            <MenuItem Header="📋 复制" Click="Copy_Click"/>
                            <MenuItem Header="📝 粘贴" Click="Paste_Click"/>
                            <MenuItem Header="📋 重命名" Click="Rename_Click"/>
                            <Separator/>
                            <MenuItem Header="ℹ️ 属性" Click="Properties_Click"/>
                            <MenuItem Header="🗑️ 删除" Click="Delete_Click"/>
                            <Separator/>
                            <MenuItem Header="🔄 刷新" Click="Refresh_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" FontSize="18" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="14" Foreground="{DynamicResource FgPrimary}"/>
                                    <TextBlock Text="{Binding Info}" FontSize="11" Foreground="{DynamicResource FgSecondary}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
        
        <!-- 状态栏 -->
        <Border Grid.Row="1" Background="{DynamicResource StatusBar}" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Foreground="{DynamicResource FgPrimary}" FontSize="12"/>
                <TextBlock x:Name="ViewModeText" Grid.Column="1" Foreground="{DynamicResource FgPrimary}" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>