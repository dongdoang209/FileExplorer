<Window x:Class="FileExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文件管理器" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgPrimary}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource BgSecondary}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="📁 文件管理器" FontSize="20" FontWeight="SemiBold" 
                          Foreground="{DynamicResource FgPrimary}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="⚙️ 设置" Style="{StaticResource NavButton}" Click="BtnSettings_Click"/>
            </Grid>
        </Border>
        
        <!-- 工具栏 -->
        <Border Grid.Row="1" Background="{DynamicResource BgToolbar}" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 导航按钮 -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="⬅ 后退" Style="{StaticResource NavButton}" Click="BtnBack_Click"/>
                    <Button Content="➡ 前进" Style="{StaticResource NavButton}" Click="BtnForward_Click"/>
                    <Button Content="⬆ 向上" Style="{StaticResource NavButton}" Click="BtnUp_Click"/>
                    <Button Content="🔄 刷新" Style="{StaticResource NavButton}" Click="BtnRefresh_Click"/>
                </StackPanel>
                
                <!-- 路径输入 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0">
                    <TextBox x:Name="TxtPath" Width="300" Style="{StaticResource NavTextBox}" 
                             VerticalContentAlignment="Center" KeyDown="TxtPath_KeyDown"/>
                    <Button Content="转到" Style="{StaticResource NavButton}" Click="BtnGo_Click" Margin="4,0"/>
                </StackPanel>
                
                <!-- 操作按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="📁 新建标签" Style="{StaticResource NavButton}" Click="BtnNewTab_Click"/>
                    <Button Content="📋 视图" Style="{StaticResource NavButton}" Click="BtnView_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Everything 搜索栏 -->
        <Border Grid.Row="2" Background="{DynamicResource BgToolbar}" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍 Everything 搜索:" Foreground="{DynamicResource FgPrimary}" 
                              VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                </StackPanel>
                
                <TextBox x:Name="TxtEverythingSearch" Grid.Column="1" Width="400" 
                         Style="{StaticResource NavTextBox}" 
                         VerticalContentAlignment="Center"
                         KeyDown="TxtEverythingSearch_KeyDown"/>
                
                <Button Grid.Column="2" Content="搜索" Style="{StaticResource NavButton}" 
                       Click="BtnEverythingSearch_Click" Margin="8,0,0,0"/>
            </Grid>
        </Border>
        
        <!-- 标签栏 -->
        <Border Grid.Row="3" Background="{DynamicResource BgSecondary}" Padding="4,0,4,0" VerticalAlignment="Top">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <ItemsControl x:Name="TabBar">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Button Content="➕" Style="{StaticResource TabButton}" Click="BtnNewTab_Click" FontSize="14" Padding="6,4" ToolTip="新建标签"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
        
        <!-- 标签内容区域 -->
        <Border Grid.Row="3" Margin="0,40,0,0">
            <Grid x:Name="TabContentArea">
                <!-- TabPage content will be loaded here -->
            </Grid>
        </Border>
        
        <!-- 状态栏 -->
        <Border Grid.Row="4" Background="{DynamicResource StatusBar}" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Foreground="{DynamicResource FgPrimary}" FontSize="12"/>
                <TextBlock x:Name="ViewModeText" Grid.Column="1" Foreground="{DynamicResource FgPrimary}" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>