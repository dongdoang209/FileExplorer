<Window x:Class="FileExplorer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgSecondary}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="⚙️ 设置" FontSize="24" FontWeight="SemiBold" 
                  Foreground="{DynamicResource FgPrimary}" Margin="0,0,0,20"/>
        
        <!-- 设置项 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
            
                <!-- 主题 -->
                <TextBlock Text="主题" FontWeight="SemiBold" 
                          Foreground="{DynamicResource FgAccent}" Margin="0,0,0,8"/>
                <ComboBox x:Name="CmbTheme" Background="{DynamicResource BgHover}" 
                         Foreground="{DynamicResource FgPrimary}" Padding="10,8" Margin="0,0,0,20">
                    <ComboBoxItem Content="🌙 深色主题"/>
                    <ComboBoxItem Content="☀️ 浅色主题"/>
                </ComboBox>
                
                <!-- 默认路径 -->
                <TextBlock Text="启动时默认路径" FontWeight="SemiBold" 
                          Foreground="{DynamicResource FgAccent}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtDefaultPath" Background="{DynamicResource BgHover}" 
                            Foreground="{DynamicResource FgPrimary}" BorderThickness="0" Padding="10,8"/>
                    <Button Grid.Column="1" Content="浏览" Style="{StaticResource NavButton}" 
                           Margin="8,0,0,0" Click="BtnBrowse_Click"/>
                </Grid>
                
                <!-- 显示设置 -->
                <TextBlock Text="显示" FontWeight="SemiBold" 
                          Foreground="{DynamicResource FgAccent}" Margin="0,0,0,8"/>
                <CheckBox x:Name="ChkShowHidden" Content="显示隐藏文件" 
                         Foreground="{DynamicResource FgPrimary}" Margin="0,0,0,8" FontSize="14"/>
                <CheckBox x:Name="ChkShowExtensions" Content="显示文件扩展名" 
                         Foreground="{DynamicResource FgPrimary}" Margin="0,0,0,8" FontSize="14"/>
                
                <!-- 排序方式 -->
                <TextBlock Text="文件排序方式" FontWeight="SemiBold" 
                          Foreground="{DynamicResource FgAccent}" Margin="0,10,0,8"/>
                <ComboBox x:Name="CmbSortBy" Background="{DynamicResource BgHover}" 
                         Foreground="{DynamicResource FgPrimary}" Padding="10,8">
                    <ComboBoxItem Content="名称 (升序)"/>
                    <ComboBoxItem Content="名称 (降序)"/>
                    <ComboBoxItem Content="大小 (升序)"/>
                    <ComboBoxItem Content="大小 (降序)"/>
                    <ComboBoxItem Content="修改时间 (最新)"/>
                    <ComboBoxItem Content="修改时间 (最早)"/>
                </ComboBox>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="保存" Style="{StaticResource NavButton}" Click="BtnSave_Click" Margin="0,0,10,0"/>
            <Button Content="取消" Style="{StaticResource NavButton}" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>