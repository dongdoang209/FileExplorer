<Application x:Class="FileExplorer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FileExplorer"
             StartupUri="MainWindow.xaml"
             Startup="Application_Startup">
    <Application.Resources>
        <!-- 默认深色主题 -->
        <SolidColorBrush x:Key="BgPrimary" Color="#1e1e1e"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#252526"/>
        <SolidColorBrush x:Key="BgToolbar" Color="#2D2D30"/>
        <SolidColorBrush x:Key="BgHover" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="BgSelected" Color="#264F78"/>
        <SolidColorBrush x:Key="FgPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="FgSecondary" Color="#888888"/>
        <SolidColorBrush x:Key="FgAccent" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="BorderColor" Color="#555555"/>
        <SolidColorBrush x:Key="StatusBar" Color="#007ACC"/>
        
        <!-- 按钮样式 -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgSelected}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Tab按钮样式 -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgToolbar}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 输入框样式 -->
        <Style x:Key="NavTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{DynamicResource FgPrimary}"/>
        </Style>
        
        <!-- 分隔线样式 -->
        <Style x:Key="NavSeparator" TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Margin" Value="8,0"/>
        </Style>
        
        <!-- 列表项样式 -->
        <Style x:Key="FileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgPrimary}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BgSelected}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>